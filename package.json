    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2",
    "vite": "^6.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.0.0"
  }
}
