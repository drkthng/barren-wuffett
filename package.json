{
  "name": "barren-wuffett",
  "version": "0.1.0",
  "description": "A free mobile-first browser game (HTML5/PWA) — Barren Wuffett, a loving parody adventure",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
